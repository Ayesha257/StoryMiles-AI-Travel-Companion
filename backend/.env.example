APP_NAME=StoryMiles API
ENVIRONMENT=development
DEBUG=false

# Local PostgreSQL (no Docker required). Create DB/user with scripts/setup_local.ps1
DATABASE_URL=postgresql+asyncpg://storymiles:storymiles@localhost:5432/storymiles

JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true

UPLOAD_DIRECTORY=uploads
# Per-photo size limit (MB). Server rejects larger payloads while reading.
MAX_PHOTO_SIZE_MB=10
MAX_PHOTOS_PER_ALBUM=50
MAX_STORAGE_PER_USER_MB=500
MAX_UPLOAD_BATCH_SIZE=10
# Compression: 1920px longest edge + JPEG q85 — see README
IMAGE_MAX_DIMENSION=1920
IMAGE_JPEG_QUALITY=85
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]

GROQ_API_KEY=
# Check available models for your account: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# Landmark scanner (Gemini vision)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Registration email verification (Gmail: use a Google App Password, not your password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-sender@gmail.com
SMTP_PASSWORD=your-16-character-google-app-password
SMTP_FROM_EMAIL=your-sender@gmail.com
SMTP_FROM_NAME=StoryMiles
VERIFICATION_CODE_EXPIRE_MINUTES=10
VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# --- Production hardening: rate limits (sliding window per user_id) ---
# Keep these low in production (cost control). Raise for local testing.
MAX_ITINERARY_REQUESTS_PER_HOUR=5
MAX_SCAN_REQUESTS_PER_HOUR=10
MAX_RECOMMENDATION_REQUESTS_PER_HOUR=30
RATE_LIMIT_WINDOW_SECONDS=3600
# Leave empty for in-memory (single worker). Set for multi-instance:
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# --- External AI timeouts & retries ---
GROQ_TIMEOUT_SECONDS=15
GEMINI_TIMEOUT_SECONDS=20
HTTP_CONNECT_TIMEOUT_SECONDS=5
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF_BASE_SECONDS=0.5

# --- Circuit breaker (trip open after N failures in window) ---
CIRCUIT_BREAKER_FAILURE_THRESHOLD=8
CIRCUIT_BREAKER_WINDOW_SECONDS=120
CIRCUIT_BREAKER_OPEN_SECONDS=300

# --- Observability ---
# Optional Sentry free-tier DSN — leave empty to disable
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
# Set true in production if you ship logs to a JSON aggregator
LOG_JSON=false
