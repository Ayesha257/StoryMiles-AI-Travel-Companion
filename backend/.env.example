APP_NAME=StoryMiles API
ENVIRONMENT=development
DEBUG=false

# Local PostgreSQL (no Docker required). Create DB/user with scripts/setup_local.ps1
DATABASE_URL=postgresql+asyncpg://storymiles:storymiles@localhost:5432/storymiles

JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true

UPLOAD_DIRECTORY=uploads
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]

GROQ_API_KEY=
# Check available models for your account: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# Landmark scanner (Gemini vision)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
